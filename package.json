{
  "name": "nori-browser",
  "version": "1.0.0",
  "description": "Browser with integrated AI terminal sidebar powered by Playwright",
  "main": "main.js",
  "scripts": {
    "build": "esbuild renderer/renderer.js --bundle --outfile=renderer/bundle.js --platform=browser --format=iife",
    "start": "npm run build && electron --no-sandbox .",
    "rebuild": "npx @electron/rebuild",
    "test": "npm run build && npx playwright test",
    "postinstall": "npx @electron/rebuild"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "node-pty": "^1.0.0",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.49.0",
    "electron": "^33.0.0",
    "esbuild": "^0.24.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
